---
import Base from "../layouts/Base.astro";
---

<Base title="These aren't the droids — 404">
  <main class="wrap" style="min-height:100svh;display:flex;flex-direction:column;justify-content:center;gap:1rem">
    <span class="lbl acc">404</span>
    <h1 style="font-size:clamp(2rem,8vw,6rem);font-weight:800;letter-spacing:-.03em;line-height:1.05">These aren't the<br />droids you're<br />looking for.</h1>
    <p style="color:var(--dim);max-width:40ch">Move along.</p>
    <p><a class="lbl acc" href="/">↳ Home</a></p>
  </main>
</Base>
